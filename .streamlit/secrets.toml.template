# Copy this file to secrets.toml and fill in your values

# OpenAI API Key (required for LLM-based modules)
OPENAI_API_KEY = "your-openai-api-key-here"

# DynamoDB table names (optional - for saving session data)
DYNAMODB_TABLE_NAME_READ = "your-read-table-name"
DYNAMODB_TABLE_NAME_WRITE = "your-write-table-name"

# Optional: LangChain tracing
# LANGCHAIN_TRACING_ENABLED = "true"
# LANGCHAIN_ENDPOINT = "https://api.smith.langchain.com"
# LANGCHAIN_API_KEY = "your-langchain-api-key"
# LANGCHAIN_PROJECT = "your-project-name"
